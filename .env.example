FLASK_ENV=development
FLASK_DEBUG=true
FLASK_HOST=127.0.0.1
FLASK_PORT=5001
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_COST_PER_1M_TOKENS=0.02
SOURCE_DOCS_DIR=data/raw
VECTOR_INDEX_DIR=data/indexes/caesar_faiss
DEFAULT_TOP_K=4
MAX_CHUNK_SIZE=1200
CHUNK_OVERLAP=150
INGEST_BATCH_SIZE=64
INGEST_SLEEP_SECONDS=0.0
INGEST_MAX_PAGES_PER_PDF=0
INGEST_MAX_CHUNKS=0
RETRIEVAL_RELEVANCE_THRESHOLD=0.6
RETRIEVAL_UTILITY_THRESHOLD=0.6
GRADER_MAX_RETRIES=2
